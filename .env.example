# Database
DATABASE_URL=postgresql://kawalgula:kawalgula_pass@postgres:5432/kawalgula?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_EXPIRES=1h

# WAHA (API client)
WAHA_API_URL=http://waha:3000
WAHA_API_KEY=waha-api-key-change-me
WAHA_SESSION_NAME=default
WAHA_TIMEOUT_MS=30000
WAHA_WEBHOOK_URL=http://api:3000/api/v1/webhooks/waha

# WAHA (container config)
WAHA_DEFAULT_SESSION_CONFIG_WEBHOOKS_0_URL=http://api:3000/api/v1/webhooks/waha
WAHA_DEFAULT_SESSION_CONFIG_WEBHOOKS_0_EVENTS=message,session.status

# Public base URL
PUBLIC_BASE_URL=https://dm.your-homelab.com

# App
APP_PORT=3000
TZ=Asia/Jakarta
ENABLE_MANUAL_REMINDER=false
