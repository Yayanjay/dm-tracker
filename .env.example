# Database
DATABASE_URL="file:./dev.db"
# PostgreSQL (prod): DATABASE_URL="postgresql://user:password@postgres:5432/dm_tracker?schema=public"

# Redis
REDIS_URL="redis://redis:6379"

# JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_ACCESS_EXPIRES="1h"
JWT_REFRESH_EXPIRES="7d"

# WAHA
WAHA_API_URL="http://waha:3000"
WAHA_API_KEY="waha-api-key-change-me"
WAHA_SESSION_NAME="default"
WAHA_WEBHOOK_URL="https://dm.your-homelab.com/webhooks/waha"

# Public base URL (for webhook callbacks registered on WAHA)
PUBLIC_BASE_URL="https://dm.your-homelab.com"

# App
APP_PORT=3000
TZ=Asia/Jakarta
