# Database
DATABASE_URL="postgresql://dm_tracker:dm_tracker_pass@localhost:5432/dm_tracker?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_ACCESS_EXPIRES="1h"
JWT_REFRESH_EXPIRES="7d"

# WAHA
WAHA_API_URL="http://localhost:3001"
WAHA_API_KEY="waha-api-key-change-me"
WAHA_SESSION_NAME="default"
WAHA_WEBHOOK_URL="http://host.docker.internal:3000/api/v1/webhooks/waha"

# Public base URL
PUBLIC_BASE_URL="http://localhost:5173"

# App
ENABLE_MANUAL_REMINDER=true
APP_PORT=3000
TZ=Asia/Jakarta
