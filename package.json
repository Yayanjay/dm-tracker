{
  "name": "kawalgula",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @kawalgula/shared build && concurrently \"pnpm --filter @kawalgula/api dev\" \"pnpm --filter @kawalgula/web dev\"",
    "build": "pnpm --filter @kawalgula/shared build && pnpm --filter @kawalgula/api build && pnpm --filter @kawalgula/web build",
    "lint": "pnpm --filter @kawalgula/api lint && pnpm --filter @kawalgula/web lint",
    "prisma:generate": "pnpm --filter @kawalgula/prisma generate",
    "prisma:migrate": "pnpm --filter @kawalgula/prisma migrate",
    "prisma:push": "pnpm --filter @kawalgula/prisma push",
    "prisma:seed": "pnpm --filter @kawalgula/prisma seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "@prisma/client": "^6.2.0",
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "concurrently": "^9.1.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "esbuild",
      "msgpackr-extract"
    ],
    "publicHoistPattern": ["@prisma/client"]
  }
}
