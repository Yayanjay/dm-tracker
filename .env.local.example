# Copy this to .env.local for local development (pnpm dev)
# .env.local is git-ignored and overrides .env

# Database (Docker containers mapped to localhost)
DATABASE_URL=postgresql://dm_tracker:dm_tracker_pass@localhost:5432/dm_tracker?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-secret
JWT_ACCESS_EXPIRES=24h

# WAHA (API client - WAHA mapped to localhost:3001)
WAHA_API_URL=http://localhost:3011
WAHA_API_KEY=waha-api-key-change-me
WAHA_SESSION_NAME=default
WAHA_WEBHOOK_URL=http://host.docker.internal:3000/api/v1/webhooks/waha

# WAHA (container config)
WAHA_DEFAULT_SESSION_CONFIG_WEBHOOKS_0_URL=http://host.docker.internal:3000/api/v1/webhooks/waha
WAHA_DEFAULT_SESSION_CONFIG_WEBHOOKS_0_EVENTS=message,session.status

# Public base URL
PUBLIC_BASE_URL=http://localhost:5173

# App
APP_PORT=3000
TZ=Asia/Jakarta
ENABLE_MANUAL_REMINDER=true
